<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>Student Record Manager</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <style>
        /* Optional: Makes the navbar look a bit more modern */
        .navbar-brand { font-weight: bold; letter-spacing: 1px; }
        .nav-link:hover { color: #198754 !important; }
    </style>
</head>
<body>
    <nav class="navbar navbar-expand-lg bg-dark navbar-dark shadow mb-4">
        <div class="container">
            <a class="navbar-brand" href="/">🎓 Record Manager</a>
            
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#mainNavbar">
                <span class="navbar-toggler-icon"></span>
            </button>

            <div class="collapse navbar-collapse" id="mainNavbar">
                <ul class="navbar-nav me-auto mb-2 mb-lg-0">
                    <li class="nav-item">
                        <a class="nav-link" href="/">Home</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" href="/new_record">Add New Record</a>
                    </li>
                </ul>

                <form class="d-flex" role="search" action="/search" method="POST">
                    <input 
                        class="form-control me-2" 
                        type="search" 
                        placeholder="Search students..." 
                        aria-label="Search" 
                        name="search" 
                        required
                    />
                    <button class="btn btn-outline-success" type="submit">Search</button>
                </form>
            </div>
        </div>
    </nav>
